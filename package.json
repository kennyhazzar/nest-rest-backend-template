{
  "name": "nest-rest-backend-template",
  "version": "1.0.0",
  "description": "Production-ready NestJS REST backend template with Drizzle ORM, CQRS, RBAC/CASL, i18n, Docker, and observability",
  "author": "",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "^22.17.* || ^24.*",
    "pnpm": "^11.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/backend/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prepare": "husky || true",
    "postinstall": "husky",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs",
    "test:unit:cov": "jest --config jest.config.cjs --coverage",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:integration": "cross-env NODE_ENV=test jest --config test/jest-integration.cjs --runInBand",
    "test:e2e": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --no-warnings --config ./test/e2e/jest/jest-e2e.cjs --runInBand",
    "test:e2e:debug": "cross-env NODE_ENV=test node --experimental-vm-modules --inspect-brk node_modules/jest/bin/jest.js --no-warnings --config ./test/e2e/jest/jest-e2e.cjs --runInBand",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.ts",
    "drizzle:migrate": "node apps/backend/scripts/migrate.cjs",
    "drizzle:migrate:test": "cross-env CONFIG_FILE=config.test.yaml node apps/backend/scripts/migrate.cjs",
    "docker": "docker compose --env-file docker/.env -f docker/docker-compose.yaml up --remove-orphans -d",
    "docker:down": "docker compose --env-file docker/.env -f docker/docker-compose.yaml down --rmi all -v"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.896.0",
    "@aws-sdk/lib-storage": "^3.896.0",
    "@casl/ability": "^7.0.0",
    "@elastic/elasticsearch": "^9.1.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.58.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "country-locale-map": "^1.9.9",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.6.1",
    "handlebars": "^4.7.8",
    "ioredis": "^5.8.0",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "nestjs-pino": "^4.4.1",
    "nestjs-s3": "^3.0.1",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-abstract-transport": "^3.0.0",
    "pino-elasticsearch": "^9.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.6",
    "sonic-boom": "^4.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.13.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/ms": "^2.1.0",
    "@types/node": "^26.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pug": "^2.0.10",
    "@types/pump": "^1.1.3",
    "@types/split2": "^4.2.3",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.44.1",
    "webpack": "^5.108.4"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
